{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/*.{svg,png,jpg,jpeg,gif,ico,css,js,json}"]
  },
  "routes": [
    {
      "route": "/privacy",
      "rewrite": "/privacy.html"
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  },
  "mimeTypes": {
    ".svg": "image/svg+xml"
  }
}
